# UniFi Controller Connection
# Replace these placeholder values with your actual UniFi controller credentials
UNIFI_HOST="192.168.1.1"
UNIFI_USERNAME="admin"
UNIFI_PASSWORD="your-password-here"
UNIFI_PORT="443"
UNIFI_SITE="default"
UNIFI_VERIFY_SSL="false"

# Optional: API key for official UniFi API access (dual auth)
# UNIFI_API_KEY=

# Configuration
# Path to custom config YAML file (optional)
CONFIG_PATH="src/config/config.yaml"

# Optional: Enable HTTP endpoint
# Set to 'true' to enable the HTTP server (default: false)
# Security note: Only enable in local development environments
UNIFI_MCP_HTTP_ENABLED="false"

# HTTP transport protocol (only applies when UNIFI_MCP_HTTP_ENABLED=true)
# Options: streamable-http (default, current MCP spec), sse (legacy)
# UNIFI_MCP_HTTP_TRANSPORT="streamable-http"

# MCP Server HTTP binding (only applies when UNIFI_MCP_HTTP_ENABLED=true)
# UNIFI_MCP_HOST="0.0.0.0"
# UNIFI_MCP_PORT="3001"

# Optional: Force HTTP in non-container environments
# By default, HTTP only starts when running as PID 1 (container main process)
# Set to 'true' to force HTTP in local development (default: false)
# UNIFI_MCP_HTTP_FORCE="false"

# Optional: Enable diagnostics/logging
# Set to 'true' to enable detailed logging for debugging (default: false)
UNIFI_MCP_DIAGNOSTICS="false"

# Optional: Auto-confirm for workflow automation
# Set to 'true' to skip confirmation prompts on mutating operations
# Ideal for n8n, Make, Zapier, and other automation platforms (default: false)
UNIFI_AUTO_CONFIRM="false"

# Optional: Allowed hosts for reverse proxy support
# Comma-separated list of hostnames allowed in the Host header
# Required when running behind a reverse proxy (e.g., Nginx)
# Default: localhost,127.0.0.1
# UNIFI_MCP_ALLOWED_HOSTS="localhost,127.0.0.1,your-domain.example.com"

# Optional: Permission overrides
# All mutation permissions are denied by default for Protect.
# Enable per-category as needed.
# UNIFI_PERMISSIONS_CAMERAS_UPDATE="true"
# UNIFI_PERMISSIONS_LIGHTS_UPDATE="true"

# Protect-specific settings
# PROTECT_EVENT_BUFFER_SIZE=100
# PROTECT_EVENT_BUFFER_TTL=300
# PROTECT_WEBSOCKET_ENABLED=true
# PROTECT_SMART_DETECTION_MIN_CONFIDENCE=50
