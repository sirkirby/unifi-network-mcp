# =============================================================================
# UniFi MCP Ecosystem — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All three servers (Network, Protect, Access) read from this file.

# ---------------------------------------------------------------------------
# Shared credentials (used by both servers if server-specific vars not set)
# ---------------------------------------------------------------------------
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your-password-here
UNIFI_PORT=443
UNIFI_VERIFY_SSL=false
# UNIFI_API_KEY=                      # Experimental — limited to read-only, subset of tools

# ---------------------------------------------------------------------------
# Network server overrides (optional — falls back to shared UNIFI_* above)
# ---------------------------------------------------------------------------
# UNIFI_NETWORK_HOST=192.168.1.1
# UNIFI_NETWORK_USERNAME=admin
# UNIFI_NETWORK_PASSWORD=
# UNIFI_NETWORK_PORT=443
# UNIFI_NETWORK_VERIFY_SSL=false
# UNIFI_NETWORK_API_KEY=              # Experimental — see above
# UNIFI_NETWORK_CONTROLLER_TYPE=auto
UNIFI_NETWORK_SITE=default

# ---------------------------------------------------------------------------
# Protect server overrides (optional — falls back to shared UNIFI_* above)
# ---------------------------------------------------------------------------
# UNIFI_PROTECT_HOST=192.168.1.1
# UNIFI_PROTECT_USERNAME=admin
# UNIFI_PROTECT_PASSWORD=
# UNIFI_PROTECT_PORT=443
# UNIFI_PROTECT_VERIFY_SSL=false
# UNIFI_PROTECT_API_KEY=              # Experimental — see above

# ---------------------------------------------------------------------------
# Access server overrides (optional — falls back to shared UNIFI_* above)
# ---------------------------------------------------------------------------
# UNIFI_ACCESS_HOST=192.168.1.1
# UNIFI_ACCESS_USERNAME=admin
# UNIFI_ACCESS_PASSWORD=
# UNIFI_ACCESS_PORT=443
# UNIFI_ACCESS_VERIFY_SSL=false
# UNIFI_ACCESS_API_KEY=
# UNIFI_ACCESS_API_PORT=12445

# ---------------------------------------------------------------------------
# MCP server settings (shared by all servers)
# ---------------------------------------------------------------------------
UNIFI_TOOL_REGISTRATION_MODE=lazy
UNIFI_MCP_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Permission Mode (default: confirm)
# Controls how mutations are handled: confirm requires preview-then-confirm, bypass executes immediately
# ---------------------------------------------------------------------------
# UNIFI_TOOL_PERMISSION_MODE=confirm
# UNIFI_NETWORK_TOOL_PERMISSION_MODE=bypass   # Per-server override

# ---------------------------------------------------------------------------
# Policy Gates (default: unset = allowed)
# Hard boundaries that disable specific actions. Most specific wins.
# ---------------------------------------------------------------------------
# UNIFI_POLICY_DELETE=false                           # Disable deletes globally
# UNIFI_POLICY_NETWORK_UPDATE=true                    # Enable updates on network server
# UNIFI_POLICY_NETWORK_NETWORKS_UPDATE=false           # Disable network category updates

# ---------------------------------------------------------------------------
# DEPRECATED: Old permission format (honored with warning, will be removed)
# ---------------------------------------------------------------------------
# UNIFI_AUTO_CONFIRM=true
# UNIFI_PERMISSIONS_<CATEGORY>_<ACTION>=true/false

# ---------------------------------------------------------------------------
# Protect event streaming
# ---------------------------------------------------------------------------
# PROTECT_EVENT_BUFFER_SIZE=100
# PROTECT_EVENT_BUFFER_TTL=300
# PROTECT_WEBSOCKET_ENABLED=true
# PROTECT_SMART_DETECTION_MIN_CONFIDENCE=50

# ---------------------------------------------------------------------------
# Access event streaming
# ---------------------------------------------------------------------------
# ACCESS_EVENT_BUFFER_SIZE=100
# ACCESS_EVENT_BUFFER_TTL=300
# ACCESS_WEBSOCKET_ENABLED=true

# ── Cloud relay (optional) ───────────────────────
# UNIFI_RELAY_URL=https://your-worker.workers.dev
# UNIFI_RELAY_TOKEN=your-relay-token
# UNIFI_RELAY_LOCATION_NAME=Home Lab
# UNIFI_RELAY_SERVERS=http://localhost:3000
# UNIFI_RELAY_REFRESH_INTERVAL=300
