{
  "name": "unifi-network",
  "version": "1.0.0",
  "description": "UniFi Network MCP server — manage network devices, clients, firewall, VPN, and more",
  "author": {
    "name": "sirkirby",
    "url": "https://github.com/sirkirby"
  },
  "license": "MIT",
  "keywords": ["unifi", "network", "firewall", "wifi", "mcp"],
  "mcpServers": {
    "unifi-network": {
      "command": "uvx",
      "args": ["unifi-network-mcp"],
      "env": {
        "UNIFI_NETWORK_HOST": "${UNIFI_NETWORK_HOST:-${UNIFI_HOST}}",
        "UNIFI_NETWORK_USERNAME": "${UNIFI_NETWORK_USERNAME:-${UNIFI_USERNAME}}",
        "UNIFI_NETWORK_PASSWORD": "${UNIFI_NETWORK_PASSWORD:-${UNIFI_PASSWORD}}",
        "UNIFI_NETWORK_API_KEY": "${UNIFI_NETWORK_API_KEY:-${UNIFI_API_KEY:-}}",
        "UNIFI_NETWORK_PORT": "${UNIFI_NETWORK_PORT:-${UNIFI_PORT:-443}}",
        "UNIFI_NETWORK_SITE": "${UNIFI_NETWORK_SITE:-${UNIFI_SITE:-default}}",
        "UNIFI_NETWORK_VERIFY_SSL": "${UNIFI_NETWORK_VERIFY_SSL:-${UNIFI_VERIFY_SSL:-false}}",
        "UNIFI_TOOL_REGISTRATION_MODE": "${UNIFI_TOOL_REGISTRATION_MODE:-lazy}"
      }
    }
  }
}
