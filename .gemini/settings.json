{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "myco-session-start",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook session-start --symbiont gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "name": "myco-user-prompt-submit",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook user-prompt-submit --symbiont gemini",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "name": "myco-post-tool-use",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook post-tool-use --symbiont gemini",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "myco-stop",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook stop --symbiont gemini",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "name": "myco-session-end",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook session-end --symbiont gemini",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "name": "myco-pre-compact",
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}\" && node .agents/myco-run.cjs hook pre-compact --symbiont gemini",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "myco": {
      "command": "myco-run",
      "args": [
        "mcp"
      ]
    }
  },
  "coreTools": [
    "ShellTool(myco *)",
    "ShellTool(myco-dev *)"
  ]
}
