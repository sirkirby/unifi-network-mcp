# UniFi Network Controller Connection
# Uses UNIFI_NETWORK_* variables. Falls back to UNIFI_* if not set.
UNIFI_NETWORK_HOST=192.168.1.1
UNIFI_NETWORK_USERNAME=admin
UNIFI_NETWORK_PASSWORD=your_password
UNIFI_NETWORK_PORT=443
UNIFI_NETWORK_SITE=default
UNIFI_NETWORK_VERIFY_SSL=false
# UNIFI_NETWORK_API_KEY=
# UNIFI_NETWORK_CONTROLLER_TYPE=auto
